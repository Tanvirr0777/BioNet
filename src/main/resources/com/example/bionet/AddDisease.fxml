<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="630.0" prefWidth="664.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bionet.dialog.AddDiseaseController">

    <children>

        <BorderPane layoutX="40.0" layoutY="20.0" prefHeight="660.0" prefWidth="620.0" stylesheets="@style.css">

            <!-- ================= TOP ================= -->

            <top>

                <Label style="-fx-font-size:20px; -fx-font-weight:bold;" text="Add New Disease">

                    <BorderPane.margin>
                        <Insets left="20" top="15" />
                    </BorderPane.margin>

                </Label>

            </top>

            <!-- ================= CENTER ================= -->

            <center>

                <VBox fx:id="addForm" prefHeight="511.0" prefWidth="559.0" spacing="12">

                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <!-- Disease Name -->

                    <Label text="Disease Name">

                        <font>
                            <Font name="System Bold" size="15" />
                        </font>

                    </Label>

                    <TextField fx:id="diseaseNameField" promptText="Enter disease name" />

                    <!-- Category -->

                    <Label text="Category">

                        <font>
                            <Font name="System Bold" size="15" />
                        </font>

                    </Label>

                    <TextField fx:id="categoryField" promptText="Enter category" />

                    <!-- Description -->

                    <Label text="Description">

                        <font>
                            <Font name="System Bold" size="15" />
                        </font>

                    </Label>

                    <TextArea fx:id="descriptionArea" prefHeight="68.0" prefWidth="580.0" promptText="Disease description" wrapText="true" />

                    <!-- Genes -->

                    <Label text="Genes">

                        <font>
                            <Font name="System Bold" size="15" />
                        </font>

                    </Label>

                    <TextArea fx:id="geneArea" prefHeight="59.0" prefWidth="580.0" promptText="One gene per line&#10;Example:&#10;BRCA1&#10;BRCA2&#10;TP53" wrapText="true" />

                    <!-- Drugs -->

                    <Label text="Drugs">

                        <font>
                            <Font name="System Bold" size="15" />
                        </font>

                    </Label>

                    <TextArea fx:id="drugArea" prefHeight="70.0" prefWidth="580.0" promptText="One drug per line&#10;Example:&#10;Tamoxifen&#10;Trastuzumab" wrapText="true" />
         
                          <!-- ================= SAVE BUTTON ================= -->
         
                          <Button fx:id="saveButton" prefHeight="35" prefWidth="90" text="Save" onAction="#handleSave">
         
                              <font>
                                 <Font name="System Bold" size="15" />
                               </font>

                          </Button>

                </VBox>

            </center>

        </BorderPane>

    </children>

</Pane>
